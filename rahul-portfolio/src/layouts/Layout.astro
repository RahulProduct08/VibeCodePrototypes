---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Rahul Kumar Ranjan — Platform & AI Systems Product Manager' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Rahul Kumar Ranjan</title>
  </head>
  <body class="bg-pearl-black text-gray-100 min-h-screen antialiased">
    <nav class="fixed top-0 inset-x-0 z-50 border-b border-rim-dim backdrop-blur-md bg-pearl-black/80">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="text-sm font-semibold tracking-widest uppercase text-blue-300 hover:text-blue-200 transition-colors">
          RKR
        </a>
        <div class="flex items-center gap-8 text-sm text-gray-400">
          <a href="/" class="hover:text-gray-100 transition-colors">Nexus</a>
          <a href="/work" class="hover:text-gray-100 transition-colors">Work</a>
          <a href="/lab" class="hover:text-gray-100 transition-colors">Lab</a>
          <a href="/collab" class="hover:text-gray-100 transition-colors">Collaborate</a>
        </div>
      </div>
    </nav>

    <main class="pt-14">
      <slot />
    </main>

    <footer class="border-t border-rim-dim mt-24 py-10 text-center text-xs text-gray-600 tracking-widest uppercase">
      &copy; {new Date().getFullYear()} Rahul Kumar Ranjan
    </footer>
  </body>
</html>
