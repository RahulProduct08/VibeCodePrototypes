---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { url } from '../utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Rahul Kumar Ranjan — Platform & AI Systems Product Manager focused on configurable platforms, workflow abstraction, and AI-enabled systems.',
  ogImage = '/og-default.png',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';

const navLinks = [
  { local: '/',       href: url('/'),       label: 'Nexus'       },
  { local: '/work',   href: url('/work'),   label: 'Work'        },
  { local: '/notes',  href: url('/notes'),  label: 'Notes'       },
  { local: '/lab',    href: url('/lab'),    label: 'Lab'         },
  { local: '/collab', href: url('/collab'), label: 'Collaborate' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} | Rahul Kumar Ranjan`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Rahul Kumar Ranjan</title>
    <ClientRouter />
  </head>

  <body>
    <!-- Cursor glow -->
    <div id="cursor-glow" aria-hidden="true"></div>

    <!-- Navigation -->
    <header class="nav-blur rim-border fixed top-0 inset-x-0 z-50 border-b" transition:persist>
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href={url('/')} aria-label="Home" class="label-caps hover:opacity-70 transition-opacity">
          RKR
        </a>

        <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
          {navLinks.map(({ local, href, label }) => {
            const isActive = local === '/'
              ? currentPath === '/'
              : currentPath.startsWith(local);
            return (
              <a
                href={href}
                class={[
                  'relative px-4 py-1.5 rounded-md text-sm transition-all duration-300',
                  isActive
                    ? 'text-white font-medium rim-border bg-blue-hour-800'
                    : 'text-steel-400 hover:text-white hover:bg-white/5',
                ].join(' ')}
                aria-current={isActive ? 'page' : undefined}
              >
                {label}
              </a>
            );
          })}
        </nav>

        <button
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden flex flex-col justify-center gap-1.5 w-8 h-8 p-1"
        >
          <span class="block h-px w-full bg-steel-300 transition-all duration-300 origin-center" id="bar-top"></span>
          <span class="block h-px w-full bg-steel-300 transition-all duration-300" id="bar-mid"></span>
          <span class="block h-px w-full bg-steel-300 transition-all duration-300 origin-center" id="bar-bot"></span>
        </button>
      </div>

      <nav
        id="mobile-menu"
        class="md:hidden hidden border-t rim-border px-6 py-4 flex flex-col gap-1"
        aria-label="Mobile navigation"
      >
        {navLinks.map(({ local, href, label }) => {
          const isActive = local === '/'
            ? currentPath === '/'
            : currentPath.startsWith(local);
          return (
            <a
              href={href}
              class={[
                'px-4 py-2 rounded-md text-sm transition-colors',
                isActive
                  ? 'text-white font-medium rim-border surface-raised'
                  : 'text-steel-400 hover:text-white hover:bg-white/5',
              ].join(' ')}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          );
        })}
      </nav>
    </header>

    <main class="pt-14">
      <slot />
    </main>

    <footer class="rim-border border-t mt-24 py-10 text-center label-caps opacity-30">
      &copy; {new Date().getFullYear()} Rahul Kumar Ranjan
    </footer>

    <script>
      // Mobile menu
      const btn  = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const barTop = document.getElementById('bar-top');
      const barMid = document.getElementById('bar-mid');
      const barBot = document.getElementById('bar-bot');

      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
        barTop?.classList.toggle('rotate-45',      open);
        barTop?.classList.toggle('translate-y-[10px]', open);
        barMid?.classList.toggle('opacity-0',      open);
        barBot?.classList.toggle('-rotate-45',     open);
        barBot?.classList.toggle('-translate-y-[6px]', open);
      });

      // Cursor glow
      const glow = document.getElementById('cursor-glow') as HTMLElement | null;
      if (glow && window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', (e) => {
          glow.style.left = e.clientX + 'px';
          glow.style.top  = e.clientY + 'px';
        });
        document.addEventListener('mouseleave', () => { glow.style.opacity = '0'; });
        document.addEventListener('mouseenter',  () => { glow.style.opacity = '1'; });
      } else if (glow) {
        glow.style.display = 'none';
      }

      // Scroll reveal — Intersection Observer
      function attachObserver() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
        );
        document.querySelectorAll('.reveal, .reveal-left, .reveal-scale')
          .forEach((el) => observer.observe(el));
      }

      attachObserver();
      document.addEventListener('astro:page-load', attachObserver);
    </script>
  </body>
</html>
