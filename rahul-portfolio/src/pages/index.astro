---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nexus">
  <section class="min-h-[90vh] flex flex-col justify-center px-6 max-w-6xl mx-auto py-24">
    <p class="text-xs tracking-widest uppercase text-blue-400 mb-6">Platform &amp; AI Systems Product Manager</p>
    <h1 class="text-4xl md:text-6xl font-bold leading-tight text-gray-50 mb-6">
      Rahul Kumar Ranjan<br />
      <span class="text-blue-300">Building the Orchestration Layer</span><br />
      for AI &amp; Enterprise.
    </h1>
    <p class="text-lg text-gray-400 max-w-2xl leading-relaxed">
      Product Manager focused on configurable platforms, workflow abstraction,
      and bridging complex business logic with AI-enabled systems.
    </p>
  </section>
</Layout>
