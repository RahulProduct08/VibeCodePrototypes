---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Card from '../components/Card.astro';
import { url } from '../utils/url';

const selectedWork = [
  {
    tag: 'Aspyr AI Labs',
    title: 'InsureDesk & AI Underwriting Engine',
    description: 'End-to-end insurance workflow platform — annuities, ROTH conversions, FAST policy administration — powered by an AI risk-scoring engine.',
    meta: '2023–Present',
    href: url('/work#aspyr'),
  },
  {
    tag: 'Mitt Arv',
    title: 'Biometric Identity & Behavioral Logic',
    description: 'Multi-modal identity verification system paired with a gamification engine that turned security touch-points into engagement drivers.',
    meta: '2022–2023',
    href: url('/work#mittarv'),
  },
];
---

<Layout title="Nexus" description="Rahul Kumar Ranjan — Building the Orchestration Layer for AI & Enterprise.">

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section
    id="hero"
    class="relative min-h-[92vh] flex flex-col justify-center px-6 overflow-hidden"
    aria-label="Hero"
  >
    <div
      class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(59,130,246,0.08) 0%, transparent 70%);"
    ></div>

    <div class="max-w-6xl mx-auto w-full py-24 flex flex-col gap-8">
      <p class="label-caps">Platform &amp; AI Systems Product Manager</p>

      <h1 class="display-xl max-w-4xl">
        Rahul Kumar Ranjan —<br />
        <span style="color: var(--color-rim-bright);">Building the Orchestration Layer</span><br />
        for AI &amp; Enterprise.
      </h1>

      <p class="body-lead max-w-2xl">
        Product Manager focused on configurable platforms, workflow abstraction,
        and bridging complex business logic with AI-enabled systems.
      </p>

      <div class="flex flex-wrap gap-4 pt-2">
        <a
          href={url('/work')}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white rim-strong transition-all hover:opacity-90"
          style="background: var(--color-blue-hour-600);"
        >
          View Work
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a
          href={url('/collab')}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5"
          style="color: var(--color-steel-200);"
        >
          Collaborate
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-30">
      <span class="label-caps" style="font-size: 0.5rem;">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-rim-bright to-transparent"></div>
    </div>
  </section>

  <!-- ── Identity Pillars ──────────────────────────────────────────────── -->
  <section id="pillars" class="px-6 py-24" aria-labelledby="pillars-heading">
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <SectionHeader
        eyebrow="Identity"
        title="Three pillars of practice."
        description="The lenses through which every product decision is made."
        id="pillars-heading"
      />

      <div class="grid md:grid-cols-3 gap-6">
        <Card
          variant="pillar"
          tag="01 — Platform"
          title="Platform Thinking"
          description="Designing scalable data management, CRUD systems, and intuitive UI/UX flows that serve as the foundation for composable products."
        >
          <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </div>
        </Card>

        <Card
          variant="pillar"
          tag="02 — AI"
          title="AI Synthesis & Prototyping"
          description="Utilizing React prototypes and generative models for precise workflow logic, identity replication, and AI-enabled decision systems."
        >
          <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
            </svg>
          </div>
        </Card>

        <Card
          variant="pillar"
          tag="03 — Theory"
          title="Cross-Domain Theory"
          description="Exploring the intersection of philosophy, acoustics, and visual aesthetics to fuel unconventional product creativity and systems thinking."
        >
          <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
              <path d="M2 20h20M4 20V10l8-8 8 8v10"/>
            </svg>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section
    id="selected-work"
    class="px-6 py-24"
    style="background: linear-gradient(to bottom, transparent, var(--color-pearl-900) 20%, var(--color-pearl-900) 80%, transparent);"
    aria-labelledby="work-heading"
  >
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <SectionHeader
          eyebrow="Selected Work"
          title="Systems built, shipped, and measured."
          id="work-heading"
        />
        <a
          href={url('/work')}
          class="shrink-0 inline-flex items-center gap-1.5 text-sm font-medium transition-opacity hover:opacity-70"
          style="color: var(--color-rim-bright);"
        >
          Full case studies
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {selectedWork.map(({ tag, title, description, meta, href }) => (
          <Card
            variant="project"
            tag={tag}
            title={title}
            description={description}
            meta={meta}
            href={href}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <section id="cta" class="px-6 py-24" aria-label="Call to action">
    <div class="max-w-6xl mx-auto grid-asymmetric items-center">
      <SectionHeader
        eyebrow="Collaborate"
        title="Reach out for doubts, lessons, or collaborations."
      />
      <div class="flex flex-col gap-5">
        <p class="body-lead">
          Mentorship · AI projects · InsurTech strategy · Platform consulting.
          If you're building something ambitious, let's talk.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={url('/collab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white rim-strong transition-all hover:opacity-90"
            style="background: var(--color-blue-hour-600);"
          >
            See collaboration tiers
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a
            href={url('/lab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5"
            style="color: var(--color-steel-300);"
          >
            Explore the Lab
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
