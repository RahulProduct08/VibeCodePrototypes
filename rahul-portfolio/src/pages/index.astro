---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Card from '../components/Card.astro';
import HeroComposition from '../components/HeroComposition';
import { url } from '../utils/url';

const selectedWork = [
  {
    tag: 'Aspyr AI Labs',
    title: 'InsureDesk & AI Underwriting Engine',
    description: 'End-to-end insurance workflow platform — annuities, ROTH conversions, FAST policy administration — powered by an AI risk-scoring engine.',
    meta: '2023–Present',
    href: url('/work#aspyr'),
  },
  {
    tag: 'Mitt Arv',
    title: 'Biometric Identity & Behavioral Logic',
    description: 'Multi-modal identity verification system paired with a gamification engine that turned security touch-points into engagement drivers.',
    meta: '2022–2023',
    href: url('/work#mittarv'),
  },
];
---

<Layout title="Nexus" description="Rahul Kumar Ranjan — Building the Orchestration Layer for AI & Enterprise.">

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section
    id="hero"
    class="relative min-h-[94vh] flex flex-col justify-center px-6 overflow-hidden"
    aria-label="Hero"
  >
    <!-- Background atmosphere -->
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-40 left-1/3 -translate-x-1/2 w-[800px] h-[800px] rounded-full"
        style="background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 65%); animation: pulseGlow 9s ease-in-out infinite;"
      ></div>
      <div
        class="absolute top-1/4 -right-64 w-[600px] h-[600px] rounded-full float float-d1"
        style="background: radial-gradient(circle, rgba(30,64,110,0.20) 0%, transparent 65%);"
      ></div>
      <div
        class="absolute bottom-0 -left-48 w-[500px] h-[500px] rounded-full float-slow float-d2"
        style="background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 65%);"
      ></div>
      <!-- Dot grid -->
      <div
        class="absolute inset-0 opacity-[0.022]"
        style="background-image: linear-gradient(rgba(96,165,250,1) 1px, transparent 1px), linear-gradient(90deg, rgba(96,165,250,1) 1px, transparent 1px); background-size: 56px 56px;"
      ></div>
    </div>

    <div class="max-w-6xl mx-auto w-full py-20 grid md:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- ── Editorial text column ─────────────────────────────────────── -->
      <div class="flex flex-col gap-8 md:py-8">
        <p class="label-caps hero-eyebrow" style="letter-spacing: 0.22em;">
          Platform &amp; AI Systems — Product Manager
        </p>

        <h1 class="display-hero hero-line-1">
          <span class="block">Building</span>
          <span class="block" style="color: var(--color-rim-bright);">the Orchestration</span>
          <span class="block hero-line-2" style="animation-delay: 0.42s;">Layer.</span>
        </h1>

        <p class="body-lead max-w-md hero-desc" style="font-size: 1rem; line-height: 1.8;">
          Configurable platforms, workflow abstraction, and AI-enabled
          decision systems — from insurance intake to biometric identity.
        </p>

        <div class="flex flex-wrap gap-4 hero-cta">
          <a
            href={url('/work')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-semibold text-white rim-strong transition-all hover:scale-105"
            style="background: var(--color-blue-hour-600);"
          >
            View Work
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href={url('/notes')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5 hover:scale-105"
            style="color: var(--color-steel-200);"
          >
            Read Notes
          </a>
        </div>

        <!-- Micro-stats row -->
        <div class="hero-cta flex items-center gap-8 pt-2" style="animation-delay: 0.80s;">
          {[
            { value: '48h', label: 'Quote-to-bind' },
            { value: '+34%', label: 'WAU lift' },
            { value: '12+', label: 'Policy types' },
          ].map(({ value, label }) => (
            <div class="flex flex-col gap-1">
              <span style="font-size: 1.2rem; font-weight: 800; color: var(--color-steel-100); letter-spacing: -0.02em;">{value}</span>
              <span style="font-size: 0.58rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-steel-600);">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- ── Floating composition column ──────────────────────────────── -->
      <div class="hidden md:block hero-visual" style="animation-delay: 0.15s;">
        <HeroComposition client:load />
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-scroll">
      <span class="label-caps opacity-30" style="font-size: 0.5rem;">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-blue-400 to-transparent opacity-30"></div>
    </div>
  </section>

  <!-- ── Identity Pillars ──────────────────────────────────────────────── -->
  <section id="pillars" class="px-6 py-24" aria-labelledby="pillars-heading">
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <div class="reveal">
        <SectionHeader
          eyebrow="Identity"
          title="Three pillars of practice."
          description="The lenses through which every product decision is made."
          id="pillars-heading"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="reveal reveal-d1">
          <Card
            variant="pillar"
            tag="01 — Platform"
            title="Platform Thinking"
            description="Designing scalable data management, CRUD systems, and intuitive UI/UX flows that serve as the foundation for composable products."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
              </svg>
            </div>
          </Card>
        </div>

        <div class="reveal reveal-d2">
          <Card
            variant="pillar"
            tag="02 — AI"
            title="AI Synthesis & Prototyping"
            description="Utilizing React prototypes and generative models for precise workflow logic, identity replication, and AI-enabled decision systems."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
          </Card>
        </div>

        <div class="reveal reveal-d3">
          <Card
            variant="pillar"
            tag="03 — Theory"
            title="Cross-Domain Theory"
            description="Exploring the intersection of philosophy, acoustics, and visual aesthetics to fuel unconventional product creativity and systems thinking."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <path d="M2 20h20M4 20V10l8-8 8 8v10"/>
              </svg>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section
    id="selected-work"
    class="px-6 py-24"
    style="background: linear-gradient(to bottom, transparent, var(--color-pearl-900) 20%, var(--color-pearl-900) 80%, transparent);"
    aria-labelledby="work-heading"
  >
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <div class="reveal flex items-end justify-between gap-6 flex-wrap">
        <SectionHeader eyebrow="Selected Work" title="Systems built, shipped, and measured." id="work-heading" />
        <a
          href={url('/work')}
          class="shrink-0 inline-flex items-center gap-1.5 text-sm font-medium transition-all hover:opacity-70 hover:gap-2.5"
          style="color: var(--color-rim-bright);"
        >
          Full case studies
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {selectedWork.map(({ tag, title, description, meta, href }, i) => (
          <div class={`reveal reveal-d${i + 1}`}>
            <Card variant="project" tag={tag} title={title} description={description} meta={meta} href={href} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <section id="cta" class="px-6 py-24" aria-label="Call to action">
    <div class="max-w-6xl mx-auto grid-asymmetric items-center">
      <div class="reveal-left">
        <SectionHeader eyebrow="Collaborate" title="Reach out for doubts, lessons, or collaborations." />
      </div>
      <div class="reveal reveal-d2 flex flex-col gap-5">
        <p class="body-lead">
          Mentorship · AI projects · InsurTech strategy · Platform consulting.
          If you're building something ambitious, let's talk.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={url('/collab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white rim-strong transition-all hover:scale-105 hover:opacity-90"
            style="background: var(--color-blue-hour-600);"
          >
            See collaboration tiers
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href={url('/lab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5 hover:scale-105"
            style="color: var(--color-steel-300);"
          >
            Explore the Lab
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
