---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Card from '../components/Card.astro';
import { url } from '../utils/url';

const selectedWork = [
  {
    tag: 'Aspyr AI Labs',
    title: 'InsureDesk & AI Underwriting Engine',
    description: 'End-to-end insurance workflow platform — annuities, ROTH conversions, FAST policy administration — powered by an AI risk-scoring engine.',
    meta: '2023–Present',
    href: url('/work#aspyr'),
  },
  {
    tag: 'Mitt Arv',
    title: 'Biometric Identity & Behavioral Logic',
    description: 'Multi-modal identity verification system paired with a gamification engine that turned security touch-points into engagement drivers.',
    meta: '2022–2023',
    href: url('/work#mittarv'),
  },
];
---

<Layout title="Nexus" description="Rahul Kumar Ranjan — Building the Orchestration Layer for AI & Enterprise.">

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section
    id="hero"
    class="relative min-h-[92vh] flex flex-col justify-center px-6 overflow-hidden"
    aria-label="Hero"
  >
    <!-- Animated background orbs -->
    <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-32 left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full"
        style="background: radial-gradient(circle, rgba(59,130,246,0.10) 0%, transparent 65%); animation: pulseGlow 8s ease-in-out infinite;"
      ></div>
      <div
        class="absolute top-1/3 -right-64 w-[500px] h-[500px] rounded-full float float-d1"
        style="background: radial-gradient(circle, rgba(30,64,110,0.25) 0%, transparent 65%);"
      ></div>
      <div
        class="absolute bottom-0 -left-48 w-[400px] h-[400px] rounded-full float-slow float-d2"
        style="background: radial-gradient(circle, rgba(59,130,246,0.07) 0%, transparent 65%);"
      ></div>
      <!-- Subtle grid pattern -->
      <div
        class="absolute inset-0 opacity-[0.025]"
        style="background-image: linear-gradient(rgba(96,165,250,1) 1px, transparent 1px), linear-gradient(90deg, rgba(96,165,250,1) 1px, transparent 1px); background-size: 60px 60px;"
      ></div>
    </div>

    <div class="max-w-6xl mx-auto w-full py-24 grid md:grid-cols-[1fr_auto] gap-12 items-center">
      <!-- Text block -->
      <div class="flex flex-col gap-8">
        <p class="label-caps hero-eyebrow">Platform &amp; AI Systems Product Manager</p>

        <h1 class="display-xl max-w-3xl">
          <span class="block hero-line-1">Rahul Kumar Ranjan —</span>
          <span class="block hero-line-2" style="color: var(--color-rim-bright);">Building the Orchestration Layer</span>
          <span class="block hero-line-2" style="animation-delay: 0.42s;">for AI &amp; Enterprise.</span>
        </h1>

        <p class="body-lead max-w-xl hero-desc">
          Product Manager focused on configurable platforms, workflow abstraction,
          and bridging complex business logic with AI-enabled systems.
        </p>

        <div class="flex flex-wrap gap-4 hero-cta">
          <a
            href={url('/work')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white rim-strong transition-all hover:scale-105"
            style="background: var(--color-blue-hour-600);"
          >
            View Work
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href={url('/collab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5 hover:scale-105"
            style="color: var(--color-steel-200);"
          >
            Collaborate
          </a>
        </div>
      </div>

      <!-- Animated node-graph visual -->
      <div class="hidden md:block hero-visual float" style="width: 260px; animation-duration: 7s;">
        <svg viewBox="0 0 260 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Connection lines (draw-in) -->
          <line x1="130" y1="50"  x2="65"  y2="130" stroke="rgba(96,165,250,0.35)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.2s var(--ease-snappy) 0.6s both;" />
          <line x1="130" y1="50"  x2="195" y2="130" stroke="rgba(96,165,250,0.35)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.2s var(--ease-snappy) 0.8s both;" />
          <line x1="65"  y1="130" x2="45"  y2="230" stroke="rgba(96,165,250,0.25)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.0s var(--ease-snappy) 1.0s both;" />
          <line x1="65"  y1="130" x2="130" y2="210" stroke="rgba(96,165,250,0.25)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.0s var(--ease-snappy) 1.1s both;" />
          <line x1="195" y1="130" x2="130" y2="210" stroke="rgba(96,165,250,0.25)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.0s var(--ease-snappy) 1.2s both;" />
          <line x1="195" y1="130" x2="215" y2="230" stroke="rgba(96,165,250,0.25)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 1.0s var(--ease-snappy) 1.3s both;" />
          <line x1="45"  y1="230" x2="90"  y2="340" stroke="rgba(96,165,250,0.18)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.9s var(--ease-snappy) 1.4s both;" />
          <line x1="130" y1="210" x2="90"  y2="340" stroke="rgba(96,165,250,0.18)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.9s var(--ease-snappy) 1.5s both;" />
          <line x1="130" y1="210" x2="170" y2="340" stroke="rgba(96,165,250,0.18)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.9s var(--ease-snappy) 1.6s both;" />
          <line x1="215" y1="230" x2="170" y2="340" stroke="rgba(96,165,250,0.18)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.9s var(--ease-snappy) 1.7s both;" />
          <line x1="90"  y1="340" x2="130" y2="400" stroke="rgba(96,165,250,0.12)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.8s var(--ease-snappy) 1.8s both;" />
          <line x1="170" y1="340" x2="130" y2="400" stroke="rgba(96,165,250,0.12)" stroke-width="1" pathLength="1" style="stroke-dasharray:1; stroke-dashoffset:1; animation: drawLine 0.8s var(--ease-snappy) 1.9s both;" />

          <!-- Glow rings on hub node -->
          <circle cx="130" cy="50" r="22" fill="rgba(59,130,246,0.06)" style="animation: pulseGlow 3s ease-in-out infinite;" />
          <circle cx="130" cy="50" r="14" fill="rgba(59,130,246,0.10)" style="animation: pulseGlow 3s ease-in-out 0.5s infinite;" />

          <!-- Nodes (draw after lines) -->
          <circle cx="130" cy="50"  r="8" fill="rgba(96,165,250,0.95)"  style="filter: drop-shadow(0 0 8px rgba(96,165,250,0.8)); animation: pulseDot 2.5s ease-in-out infinite 0.0s;" />
          <circle cx="65"  cy="130" r="5" fill="rgba(96,165,250,0.80)"  style="filter: drop-shadow(0 0 6px rgba(96,165,250,0.6)); animation: pulseDot 2.5s ease-in-out infinite 0.3s;" />
          <circle cx="195" cy="130" r="5" fill="rgba(96,165,250,0.80)"  style="filter: drop-shadow(0 0 6px rgba(96,165,250,0.6)); animation: pulseDot 2.5s ease-in-out infinite 0.6s;" />
          <circle cx="45"  cy="230" r="4" fill="rgba(96,165,250,0.60)"  style="animation: pulseDot 2.5s ease-in-out infinite 0.9s;" />
          <circle cx="130" cy="210" r="6" fill="rgba(96,165,250,0.85)"  style="filter: drop-shadow(0 0 5px rgba(96,165,250,0.5)); animation: pulseDot 2.5s ease-in-out infinite 1.2s;" />
          <circle cx="215" cy="230" r="4" fill="rgba(96,165,250,0.60)"  style="animation: pulseDot 2.5s ease-in-out infinite 1.5s;" />
          <circle cx="90"  cy="340" r="4" fill="rgba(96,165,250,0.50)"  style="animation: pulseDot 2.5s ease-in-out infinite 1.8s;" />
          <circle cx="170" cy="340" r="4" fill="rgba(96,165,250,0.50)"  style="animation: pulseDot 2.5s ease-in-out infinite 2.1s;" />
          <circle cx="130" cy="400" r="3" fill="rgba(96,165,250,0.35)"  style="animation: pulseDot 2.5s ease-in-out infinite 2.4s;" />

          <!-- Labels -->
          <text x="144" y="46" font-size="7" fill="rgba(96,165,250,0.7)" font-family="monospace">platform</text>
          <text x="28"  y="126" font-size="6" fill="rgba(96,165,250,0.5)" font-family="monospace">auth</text>
          <text x="200" y="126" font-size="6" fill="rgba(96,165,250,0.5)" font-family="monospace">ai</text>
          <text x="138" y="207" font-size="6" fill="rgba(96,165,250,0.5)" font-family="monospace">core</text>
        </svg>
      </div>
    </div>

    <!-- Scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-scroll">
      <span class="label-caps opacity-30" style="font-size: 0.5rem;">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-rim-bright to-transparent opacity-30"></div>
    </div>
  </section>

  <!-- ── Identity Pillars ──────────────────────────────────────────────── -->
  <section id="pillars" class="px-6 py-24" aria-labelledby="pillars-heading">
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <div class="reveal">
        <SectionHeader
          eyebrow="Identity"
          title="Three pillars of practice."
          description="The lenses through which every product decision is made."
          id="pillars-heading"
        />
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="reveal reveal-d1">
          <Card
            variant="pillar"
            tag="01 — Platform"
            title="Platform Thinking"
            description="Designing scalable data management, CRUD systems, and intuitive UI/UX flows that serve as the foundation for composable products."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
              </svg>
            </div>
          </Card>
        </div>

        <div class="reveal reveal-d2">
          <Card
            variant="pillar"
            tag="02 — AI"
            title="AI Synthesis & Prototyping"
            description="Utilizing React prototypes and generative models for precise workflow logic, identity replication, and AI-enabled decision systems."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
          </Card>
        </div>

        <div class="reveal reveal-d3">
          <Card
            variant="pillar"
            tag="03 — Theory"
            title="Cross-Domain Theory"
            description="Exploring the intersection of philosophy, acoustics, and visual aesthetics to fuel unconventional product creativity and systems thinking."
          >
            <div slot="icon" class="w-10 h-10 rounded-lg rim-border flex items-center justify-center mb-1" style="background: rgba(59,130,246,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-rim-bright);" aria-hidden="true">
                <path d="M2 20h20M4 20V10l8-8 8 8v10"/>
              </svg>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section
    id="selected-work"
    class="px-6 py-24"
    style="background: linear-gradient(to bottom, transparent, var(--color-pearl-900) 20%, var(--color-pearl-900) 80%, transparent);"
    aria-labelledby="work-heading"
  >
    <div class="max-w-6xl mx-auto flex flex-col gap-12">
      <div class="reveal flex items-end justify-between gap-6 flex-wrap">
        <SectionHeader eyebrow="Selected Work" title="Systems built, shipped, and measured." id="work-heading" />
        <a
          href={url('/work')}
          class="shrink-0 inline-flex items-center gap-1.5 text-sm font-medium transition-all hover:opacity-70 hover:gap-2.5"
          style="color: var(--color-rim-bright);"
        >
          Full case studies
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {selectedWork.map(({ tag, title, description, meta, href }, i) => (
          <div class={`reveal reveal-d${i + 1}`}>
            <Card variant="project" tag={tag} title={title} description={description} meta={meta} href={href} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────── -->
  <section id="cta" class="px-6 py-24" aria-label="Call to action">
    <div class="max-w-6xl mx-auto grid-asymmetric items-center">
      <div class="reveal-left">
        <SectionHeader eyebrow="Collaborate" title="Reach out for doubts, lessons, or collaborations." />
      </div>
      <div class="reveal reveal-d2 flex flex-col gap-5">
        <p class="body-lead">
          Mentorship · AI projects · InsurTech strategy · Platform consulting.
          If you're building something ambitious, let's talk.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={url('/collab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium text-white rim-strong transition-all hover:scale-105 hover:opacity-90"
            style="background: var(--color-blue-hour-600);"
          >
            See collaboration tiers
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href={url('/lab')}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-sm font-medium rim-border transition-all hover:bg-white/5 hover:scale-105"
            style="color: var(--color-steel-300);"
          >
            Explore the Lab
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
