---
import Layout from '../layouts/Layout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Card from '../components/Card.astro';
import MermaidDiagram from '../components/MermaidDiagram.astro';
import ImageContainer from '../components/ImageContainer.astro';

const insuredeskDiagram = `flowchart TD
    A([Agent / Broker]) --> B[InsureDesk Portal]
    B --> C{Select Product}
    C -->|Annuity| D[Annuity Intake]
    C -->|Life / Term| E[Life Policy Intake]
    C -->|ROTH Conversion| F[ROTH Conversion Flow]
    D --> G[Document Collection]
    E --> G
    F --> G
    G --> H[AI Underwriting Engine]
    H --> I{Risk Score}
    I -->|Low Risk| J[Auto-Approve]
    I -->|Medium Risk| K[Underwriter Queue]
    I -->|High Risk| L[Decline or Refer]
    J --> M[FAST Policy Admin]
    K --> N[Manual Review]
    N --> M
    M --> O[Policy Issuance]
    O --> P[Client Portal]
    P --> Q[Ongoing Admin]`;

const mittarvDiagram = `flowchart TD
    A([New User]) --> B[Enrollment Flow]
    B --> C{Biometric Capture}
    C -->|Face Scan| D[Face Vector Store]
    C -->|Fingerprint| E[Ridge Hash Store]
    C -->|Behavioral| F[Interaction Baseline]
    D --> G[Identity Profile]
    E --> G
    F --> G
    G --> H[Continuous Auth Engine]
    H --> I{Confidence Score}
    I -->|High 95+| J[Full Access]
    I -->|Medium 70-94| K[Step-Up Challenge]
    I -->|Low below 70| L[Session Lock]
    J --> M[Gamification Engine]
    M --> N{Behavioral Logic}
    N -->|Engagement Streak| O[Reward Token]
    N -->|Anomaly Detected| P[Security Alert]`;
---

<Layout title="Work & Systems" description="Professional engagements — InsureDesk, AI Underwriting Engines, and the Mitt Arv biometric platform.">

  <!-- ── Page header ───────────────────────────────────────────────────── -->
  <section class="relative px-6 pt-24 pb-16 overflow-hidden" aria-label="Page header">
    <div class="pointer-events-none absolute inset-0 -z-10"
      style="background: radial-gradient(ellipse 60% 40% at 20% 0%, rgba(59,130,246,0.07) 0%, transparent 70%);"></div>
    <div class="max-w-6xl mx-auto reveal">
      <SectionHeader
        eyebrow="Work & Systems"
        title="Professional Engagements"
        description="Building orchestration layers, AI underwriting engines, and identity platforms — end to end."
      />
    </div>
  </section>

  <!-- ── Aspyr AI Labs ─────────────────────────────────────────────────── -->
  <section id="aspyr" class="px-6 py-20" aria-labelledby="aspyr-heading">
    <div class="max-w-6xl mx-auto flex flex-col gap-14">

      <div class="grid-asymmetric items-start">
        <!-- Left: context -->
        <div class="flex flex-col gap-6">
          <div class="reveal-left">
            <SectionHeader
              eyebrow="Aspyr AI Labs · 2023–Present"
              title="InsureDesk & AI Underwriting"
              id="aspyr-heading"
              description="Configurable platform layer that transforms opaque insurance processes into auditable, orchestrated workflows."
            />
          </div>
          <ul class="reveal flex flex-col gap-3 text-sm" style="color: var(--color-steel-400);">
            {[
              'Mapped 40+ annuity and life policy edge cases into a unified intake schema, eliminating 3 legacy paper forms.',
              "Designed the AI Underwriting Engine's risk-scoring rubric: FICO inputs, medical flags, and product-specific riders.",
              'Integrated FAST policy administration as the downstream execution layer for auto-approved cases.',
              'Reduced average quote-to-bind time from 11 days to under 48 hours for standard-risk profiles.',
            ].map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full" style="background: var(--color-rim-bright);"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: image + cards -->
        <div class="flex flex-col gap-4">
          <div class="reveal">
            <ImageContainer alt="InsureDesk platform dashboard" seed="insurance-dashboard" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="reveal reveal-d1"><Card variant="stat" tag="Efficiency" title="Quote-to-Bind" number="48h" /></div>
            <div class="reveal reveal-d2"><Card variant="stat" tag="Coverage"   title="Policy Types"  number="12+" /></div>
          </div>
          <div class="reveal reveal-d1">
            <Card variant="project" tag="Core Product" title="InsureDesk"
              description="Configurable SaaS portal for insurance agents handling annuities, life policies, and ROTH conversions with a dynamic form engine." />
          </div>
          <div class="reveal reveal-d2">
            <Card variant="project" tag="AI Engine" title="AI Underwriting Engine"
              description="LLM-assisted risk assessment trained on carrier guidelines. Classifies into auto-approve, manual review, or decline tracks." />
          </div>
          <div class="reveal reveal-d3">
            <Card variant="project" tag="Workflow" title="ROTH Conversion Orchestrator"
              description="Multi-step workflow covering tax implication surfacing, contribution limit validation, and custodian handoff in a single guided session." />
          </div>
        </div>
      </div>

      <div class="reveal">
        <MermaidDiagram id="insuredesk-diagram" title="InsureDesk — End-to-End Workflow" diagram={insuredeskDiagram} />
      </div>

    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-6xl mx-auto px-6"><div class="rim-border border-t opacity-40"></div></div>

  <!-- ── Mitt Arv ───────────────────────────────────────────────────────── -->
  <section id="mittarv" class="px-6 py-20" aria-labelledby="mittarv-heading">
    <div class="max-w-6xl mx-auto flex flex-col gap-14">

      <div class="grid-asymmetric items-start">
        <!-- Left: context -->
        <div class="flex flex-col gap-6">
          <div class="reveal-left">
            <SectionHeader
              eyebrow="Mitt Arv · 2022–2023"
              title="Identity & Behavioral Logic"
              id="mittarv-heading"
              description="Multi-modal biometric security layer and a gamification engine that drives sustained engagement through behavioral incentives."
            />
          </div>
          <ul class="reveal flex flex-col gap-3 text-sm" style="color: var(--color-steel-400);">
            {[
              'Defined the biometric enrollment flow: face vector extraction, fingerprint ridge hashing, and behavioral baseline capture.',
              'Designed a continuous authentication confidence model — three-tier response: full access, step-up challenge, session lock.',
              'Built the gamification logic engine: streak tracking, reward token issuance, and anomaly-triggered security nudges.',
              'Achieved 34% increase in weekly active users within 60 days of gamification rollout.',
            ].map((item) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 shrink-0 w-1.5 h-1.5 rounded-full" style="background: var(--color-rim-bright);"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: image + cards -->
        <div class="flex flex-col gap-4">
          <div class="reveal">
            <ImageContainer alt="Mitt Arv biometric identity platform" seed="biometric-security" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="reveal reveal-d1"><Card variant="stat" tag="Engagement" title="WAU Lift"            number="+34%" /></div>
            <div class="reveal reveal-d2"><Card variant="stat" tag="Auth"       title="Confidence Threshold" number="95%"  /></div>
          </div>
          <div class="reveal reveal-d1">
            <Card variant="project" tag="Security Layer" title="Biometric Identity System"
              description="Multi-modal identity verification combining face vectors, fingerprint hashes, and behavioral signals. Re-scores sessions every 90 seconds without interrupting UX." />
          </div>
          <div class="reveal reveal-d2">
            <Card variant="project" tag="Behavioral Logic Engine" title="Gamification System"
              description="Engagement loop built on streak mechanics, milestone rewards, and behavioral anomaly detection. Rewards issued as on-platform tokens." />
          </div>
        </div>
      </div>

      <div class="reveal">
        <MermaidDiagram id="mittarv-diagram" title="Mitt Arv — Biometric Identity & Gamification Architecture" diagram={mittarvDiagram} />
      </div>

    </div>
  </section>

</Layout>
