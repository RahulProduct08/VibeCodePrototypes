---
type Variant  = 'default' | 'info' | 'success' | 'warning' | 'danger';
type NodeType = 'entry' | 'process' | 'decision' | 'ai' | 'output' | 'terminal';

interface Branch {
  label: string;
  sublabel?: string;
  variant?: Variant;
}

export interface FlowStep {
  label: string;
  sublabel?: string;
  type: NodeType;
  branches?: Branch[];
}

interface Props {
  steps: FlowStep[];
  title?: string;
  id?: string;
}

const { steps, title, id } = Astro.props;

/* Position of each branch as % of container width */
function bpos(n: number, i: number) {
  return (((2 * i + 1) / (2 * n)) * 100).toFixed(2);
}

const nodeCfg: Record<NodeType, { border: string; bg: string; glyph: string; glyphColor: string }> = {
  entry:    { border: 'rgba(130,154,177,0.28)', bg: 'rgba(14,21,37,0.90)',  glyph: 'INPUT',    glyphColor: '#829ab1' },
  process:  { border: 'rgba(59,130,246,0.22)',  bg: 'rgba(10,15,26,0.95)',  glyph: 'PROCESS',  glyphColor: '#627d98' },
  decision: { border: 'rgba(59,130,246,0.52)',  bg: 'rgba(15,32,66,0.55)',  glyph: 'DECISION', glyphColor: '#60a5fa' },
  ai:       { border: 'rgba(96,165,250,0.70)',  bg: 'rgba(10,22,40,0.95)',  glyph: 'AI',       glyphColor: '#60a5fa' },
  output:   { border: 'rgba(96,165,250,0.38)',  bg: 'rgba(10,15,26,0.95)',  glyph: 'OUTPUT',   glyphColor: '#60a5fa' },
  terminal: { border: 'rgba(130,154,177,0.18)', bg: 'rgba(6,9,15,0.98)',   glyph: 'END',      glyphColor: '#486581' },
};

const varCfg: Record<Variant, { border: string; bg: string; text: string; dot: string }> = {
  default: { border: 'rgba(59,130,246,0.28)',  bg: 'rgba(15,32,66,0.30)',  text: '#bcccdc', dot: '#3b82f6' },
  info:    { border: 'rgba(59,130,246,0.35)',  bg: 'rgba(15,32,66,0.38)',  text: '#bcccdc', dot: '#60a5fa' },
  success: { border: 'rgba(34,197,94,0.48)',   bg: 'rgba(6,78,59,0.18)',   text: '#86efac', dot: '#22c55e' },
  warning: { border: 'rgba(245,158,11,0.48)',  bg: 'rgba(120,53,15,0.18)', text: '#fcd34d', dot: '#f59e0b' },
  danger:  { border: 'rgba(239,68,68,0.48)',   bg: 'rgba(127,29,29,0.18)', text: '#fca5a5', dot: '#ef4444' },
};

let globalDelay = 0;
function nextDelay(inc = 0.10): string {
  globalDelay += inc;
  return `${globalDelay.toFixed(2)}s`;
}
---

<div class="wf-root" id={id}>
  {title && (
    <div class="wf-title-row reveal" style={`transition-delay: 0s`}>
      <span class="label-caps">{title}</span>
    </div>
  )}

  {steps.map((step, si) => {
    const cfg  = nodeCfg[step.type];
    const hasBranches = step.branches && step.branches.length > 0;
    const n    = step.branches?.length ?? 0;
    const isLast = si === steps.length - 1;
    const nodeDelay = nextDelay(0.08);

    return (
      <div class="wf-step-group">

        {/* ── Main node card ────────────────────────────────────── */}
        <div
          class={`wf-node reveal ${step.type === 'ai' ? 'wf-node-ai' : ''}`}
          style={`--border-c:${cfg.border}; --bg-c:${cfg.bg}; transition-delay:${nodeDelay};`}
        >
          {step.type === 'ai' && <div class="ai-ring ai-ring-1" aria-hidden="true"></div>}
          {step.type === 'ai' && <div class="ai-ring ai-ring-2" aria-hidden="true"></div>}

          <div class="wf-node-inner">
            <span class="wf-glyph" style={`color:${cfg.glyphColor}`}>{cfg.glyph}</span>
            <div class="wf-node-text">
              <strong class="wf-label">{step.label}</strong>
              {step.sublabel && <span class="wf-sub">{step.sublabel}</span>}
            </div>
          </div>
        </div>

        {/* ── Branches (fork → cards → merge) ──────────────────── */}
        {hasBranches && (
          <div class="wf-branches-wrap">

            {/* Fork SVG — draws from center to N branch positions */}
            <svg
              class="wf-fork-svg reveal"
              viewBox={`0 0 100 28`}
              preserveAspectRatio="none"
              style={`transition-delay:${nextDelay(0.06)}`}
              aria-hidden="true"
            >
              {/* Centre stem */}
              <line
                x1="50%" y1="0" x2="50%" y2="55%"
                stroke="rgba(59,130,246,0.45)" stroke-width="1.2"
                pathLength="1"
                style="stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.5s var(--ease-snappy) var(--fork-d,0s) both"
              />
              {/* Horizontal bar */}
              <line
                x1={`${bpos(n, 0)}%`} y1="55%" x2={`${bpos(n, n - 1)}%`} y2="55%"
                stroke="rgba(59,130,246,0.35)" stroke-width="1.2"
                pathLength="1"
                style="stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.5s var(--ease-snappy) calc(var(--fork-d,0s) + 0.15s) both"
              />
              {/* Drop lines to each branch */}
              {step.branches!.map((_, bi) => (
                <line
                  x1={`${bpos(n, bi)}%`} y1="55%" x2={`${bpos(n, bi)}%`} y2="100%"
                  stroke="rgba(59,130,246,0.30)" stroke-width="1.2"
                  pathLength="1"
                  style={`stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.4s var(--ease-snappy) calc(var(--fork-d,0s) + ${(0.2 + bi * 0.06).toFixed(2)}s) both`}
                />
              ))}
            </svg>

            {/* Branch cards */}
            <div class="wf-branches-row">
              {step.branches!.map((branch, bi) => {
                const vc  = varCfg[branch.variant ?? 'info'];
                const bDelay = nextDelay(0.06);
                return (
                  <div
                    class="wf-branch reveal"
                    style={`--b-border:${vc.border};--b-bg:${vc.bg};--b-text:${vc.text};--b-dot:${vc.dot};transition-delay:${bDelay}`}
                  >
                    <span class="wf-branch-dot" aria-hidden="true"></span>
                    <span class="wf-branch-label">{branch.label}</span>
                    {branch.sublabel && <span class="wf-branch-sub">{branch.sublabel}</span>}
                  </div>
                );
              })}
            </div>

            {/* Merge SVG — rises from N branch positions back to centre */}
            <svg
              class="wf-merge-svg reveal"
              viewBox="0 0 100 28"
              preserveAspectRatio="none"
              style={`transition-delay:${nextDelay(0.06)}`}
              aria-hidden="true"
            >
              {step.branches!.filter((_, bi) => {
                const v = step.branches![bi].variant ?? 'info';
                return v !== 'danger';
              }).map((_, bi) => {
                const actualBi = step.branches!.findIndex((b, idx) => {
                  const v = b.variant ?? 'info';
                  return v !== 'danger' && idx >= bi;
                });
                return (
                  <line
                    x1={`${bpos(n, bi)}%`} y1="0" x2={`${bpos(n, bi)}%`} y2="45%"
                    stroke="rgba(59,130,246,0.25)" stroke-width="1.2"
                    pathLength="1"
                    style={`stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.4s var(--ease-snappy) calc(var(--merge-d,0s) + ${(bi * 0.05).toFixed(2)}s) both`}
                  />
                );
              })}
              <line
                x1={`${bpos(n, 0)}%`} y1="45%" x2={`${bpos(n, n - 1)}%`} y2="45%"
                stroke="rgba(59,130,246,0.25)" stroke-width="1.2"
                pathLength="1"
                style="stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.5s var(--ease-snappy) calc(var(--merge-d,0s) + 0.20s) both"
              />
              <line
                x1="50%" y1="45%" x2="50%" y2="100%"
                stroke="rgba(59,130,246,0.35)" stroke-width="1.2"
                pathLength="1"
                style="stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.4s var(--ease-snappy) calc(var(--merge-d,0s) + 0.30s) both"
              />
            </svg>
          </div>
        )}

        {/* ── Straight connector to next step ───────────────────── */}
        {!isLast && (
          <div class="wf-connector reveal" style={`transition-delay:${nextDelay(0.05)}`} aria-hidden="true">
            <svg viewBox="0 0 2 40" preserveAspectRatio="none" width="2" height="40">
              <line
                x1="1" y1="0" x2="1" y2="40"
                stroke="rgba(59,130,246,0.40)" stroke-width="2"
                pathLength="1"
                style="stroke-dasharray:1;stroke-dashoffset:1;animation:drawLine 0.5s var(--ease-snappy) var(--conn-d,0s) both"
              />
            </svg>
            {/* Flowing dot */}
            <span class="wf-flow-dot" aria-hidden="true"></span>
          </div>
        )}

      </div>
    );
  })}
</div>

<style>
  /* ── Container ─────────────────────────────────────────────── */
  .wf-root {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: 100%;
    padding: 2rem 1rem;
  }

  .wf-title-row {
    margin-bottom: 2rem;
    letter-spacing: 0.14em;
  }

  .wf-step-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 640px;
  }

  /* ── Node card ─────────────────────────────────────────────── */
  .wf-node {
    position: relative;
    width: 100%;
    max-width: 440px;
    border: 1px solid var(--border-c, rgba(59,130,246,0.2));
    background: var(--bg-c, rgba(10,15,26,0.9));
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    transition:
      border-color 0.3s var(--ease-snappy),
      box-shadow   0.3s var(--ease-snappy),
      transform    0.3s var(--ease-snappy);
    overflow: hidden;
    z-index: 1;
  }

  .wf-node:hover {
    transform: scale(1.02);
    box-shadow: 0 0 24px rgba(59,130,246,0.14), 0 0 48px rgba(59,130,246,0.06);
  }

  .wf-node-inner {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .wf-glyph {
    font-size: 0.45rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    font-family: var(--font-mono);
    opacity: 0.8;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    flex-shrink: 0;
  }

  .wf-node-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .wf-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-steel-100);
    line-height: 1.3;
  }

  .wf-sub {
    font-size: 0.7rem;
    color: var(--color-steel-500);
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  /* ── AI special node ────────────────────────────────────────── */
  .wf-node-ai .wf-label { color: var(--color-rim-bright); }

  .ai-ring {
    position: absolute;
    inset: -4px;
    border-radius: inherit;
    pointer-events: none;
    border: 1px solid rgba(96,165,250,0.3);
  }

  .ai-ring-1 { animation: pulseGlow 2.5s ease-in-out infinite; }
  .ai-ring-2 { animation: pulseGlow 2.5s ease-in-out 0.8s infinite; inset: -8px; }

  /* ── Straight connector ─────────────────────────────────────── */
  .wf-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    height: 40px;
  }

  /* Animated flowing dot along the connector line */
  .wf-flow-dot {
    position: absolute;
    top: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-rim-bright);
    box-shadow: 0 0 6px var(--color-rim-bright);
    animation: flowDown 2.2s ease-in-out infinite 0.5s;
  }

  @keyframes flowDown {
    0%   { top: 0;    opacity: 0; }
    15%  { opacity: 1; }
    85%  { opacity: 1; }
    100% { top: 36px; opacity: 0; }
  }

  /* ── Branches ───────────────────────────────────────────────── */
  .wf-branches-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .wf-fork-svg,
  .wf-merge-svg {
    width: 100%;
    height: 28px;
    overflow: visible;
  }

  .wf-branches-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
  }

  .wf-branch {
    flex: 1;
    min-width: 120px;
    max-width: 200px;
    border: 1px solid var(--b-border);
    background: var(--b-bg);
    border-radius: 0.6rem;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    transition: transform 0.25s var(--ease-snappy), box-shadow 0.25s var(--ease-snappy);
  }

  .wf-branch:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 20px rgba(59,130,246,0.12);
  }

  .wf-branch-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--b-dot);
    box-shadow: 0 0 6px var(--b-dot);
    margin-bottom: 0.25rem;
    animation: pulseDot 2s ease-in-out infinite;
  }

  .wf-branch-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--b-text);
    line-height: 1.3;
  }

  .wf-branch-sub {
    font-size: 0.65rem;
    color: var(--color-steel-600);
    font-family: var(--font-mono);
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .wf-branches-row { flex-direction: column; align-items: center; }
    .wf-branch       { max-width: 100%; width: 100%; }
  }
</style>
