---
interface Props {
  src?: string;
  alt: string;
  caption?: string;
  label?: string;
  seed?: string;
  placeholder?: boolean;
  class?: string;
}

const {
  src,
  alt,
  caption,
  label,
  seed,
  placeholder = false,
  class: className = '',
} = Astro.props;

const imgSeed = seed ?? alt.toLowerCase().replace(/[^a-z0-9]/g, '-').slice(0, 24);
const picsumSrc = `https://picsum.photos/seed/${imgSeed}/405/720`;
const finalSrc = (!placeholder && src) ? src : picsumSrc;
---

<figure class={`relative w-full aspect-9-16 rim-card img-zoom overflow-hidden rounded-xl ${className}`}>
  <img
    src={finalSrc}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full h-full object-cover"
  />

  <!-- Gradient overlay — always present for legibility -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent pointer-events-none"
  ></div>

  <!-- Label tag (top-left) -->
  {label && (
    <div class="absolute top-3 left-3 px-2 py-1 rounded-md text-xs font-medium tracking-wide bg-pearl-black/70 backdrop-blur-sm border rim-border text-steel-200">
      {label}
    </div>
  )}

  <!-- Caption (bottom overlay) -->
  {caption && (
    <figcaption class="absolute bottom-0 inset-x-0 px-4 py-4 text-xs leading-relaxed text-steel-200">
      {caption}
    </figcaption>
  )}
</figure>
