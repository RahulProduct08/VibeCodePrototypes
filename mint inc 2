};

// --- NEW COMPUTE PAGE COMPONENT ---
const ComputePage = ({ item, setEditingItem }) => {
    const [expandedSections, setExpandedSections] = useState({
        configuration: true,
        mapping: true
    });
    
    // Configuration State
    const [config, setConfig] = useState({
        name: item.name || 'Interest Calculation',
        category: 'Finance',
        description: item.summary || 'Calculates simple and compound interest based on provided inputs.',
        type: 'Excel',
        fileName: 'interest_logic.xlsx'
    });
    const [errors, setErrors] = useState({});

    // Mapping & Testing State
    const [activeTab, setActiveTab] = useState('input');
    
    const [inputMappings, setInputMappings] = useState([
        { id: 1, fieldName: 'principal', sheet: 'Sheet1', cell: 'B1', dataType: 'Number', status: 'mapped' },
        { id: 2, fieldName: 'rate', sheet: 'Sheet1', cell: 'B2', dataType: 'Percentage', status: 'mapped' },
        { id: 3, fieldName: 'time', sheet: 'Sheet1', cell: 'B3', dataType: 'Number', status: 'mapped' }
    ]);

    const [outputMappings, setOutputMappings] = useState([
        { id: 1, fieldName: 'total_amount', sheet: 'Sheet1', cell: 'C5', dataType: 'Currency', status: 'mapped' }
    ]);

    const [draggedIndex, setDraggedIndex] = useState(null);

    // Test State
    const [testInputs, setTestInputs] = useState({
        interest: '7',
        principal: '10000',
        time: '5'
    });
    const [testHistory, setTestHistory] = useState([
        { id: 1, inputs: { interest: 7, principal: 10000, time: 5 }, result: 14025.52, timestamp: '2 min ago' },
        { id: 2, inputs: { interest: 5, principal: 15000, time: 3 }, result: 17364.38, timestamp: '5 min ago' }
    ]);

    // --- LOGIC FUNCTIONS ---
    const toggleSection = (section) => {
        setExpandedSections(prev => ({ ...prev, [section]: !prev[section] }));
    };
    
    const handleConfigChange = (e) => {
        const { name, value } = e.target;
        setConfig(prev => ({ ...prev, [name]: value }));
        if (errors[name]) setErrors(prev => ({ ...prev, [name]: null }));
    };

    const handleFileChange = () => {
        setConfig(prev => ({ ...prev, fileName: 'new_interest_logic.xlsx' }));
        if (errors.fileName) {
            const newErrors = { ...errors };
            delete newErrors.fileName;
            setErrors(newErrors);
        }
    };

    const validateAndCollapse = () => {
        const newErrors = {};
        if (!config.name.trim()) newErrors.name = "Name is required.";
        if (!config.category) newErrors.category = "Category is required.";
        if (!config.type) newErrors.type = "Type is required.";
        if (!config.fileName) newErrors.fileName = "A file must be uploaded.";
        setErrors(newErrors);
        if (Object.keys(newErrors).length === 0) {
            toggleSection('configuration');
        }
    };

    const handleDragStart = (e, index) => {
        setDraggedIndex(index);
        e.dataTransfer.effectAllowed = 'move';
    };

    const handleDragOver = (e) => e.preventDefault();

    const handleDrop = (e, dropIndex, list, setList) => {
        e.preventDefault();
        if (draggedIndex === null) return;
        const newList = [...list];
        const draggedItem = newList[draggedIndex];
        newList.splice(draggedIndex, 1);
        newList.splice(dropIndex, 0, draggedItem);
        setList(newList);
        setDraggedIndex(null);
    };

    const addNewMapping = (type) => {
        const list = type === 'input' ? inputMappings : outputMappings;
        const setList = type === 'input' ? setInputMappings : setOutputMappings;
        const newMapping = { id: list.length + 1, fieldName: `new_${type}`, sheet: 'Sheet1', cell: 'A4', dataType: 'Number', status: 'pending' };
        setList(prev => [...prev, newMapping]);
    };

    const deleteMapping = (id, type) => {
        const setList = type === 'input' ? setInputMappings : setOutputMappings;
        setList(prev => prev.filter(m => m.id !== id));
    };

    const handleTestInputChange = (field, value) => {
        setTestInputs(prev => ({ ...prev, [field]: value }));
    };

    const handleCompute = () => {
        const principal = parseFloat(testInputs.principal);
        const rate = parseFloat(testInputs.interest) / 100;
        const time = parseFloat(testInputs.time);
        
        if (isNaN(principal) || isNaN(rate) || isNaN(time)) return;

        const compoundInterest = principal * Math.pow(1 + rate, time) - principal;
        const totalAmount = principal + compoundInterest;
        const newTest = {
            id: testHistory.length + 1,
            inputs: { interest: parseFloat(testInputs.interest), principal, time },
            result: totalAmount,
            timestamp: 'Just now'
        };
        setTestHistory(prev => [newTest, ...prev.slice(0, 4)]);
    };

