const DashboardLayout = () => {
    const [activeItem, setActiveItem] = useState('Dashboard');
    const [modalContent, setModalContent] = useState(null);
    const [isNotificationsOpen, setNotificationsOpen] = useState(false);
    const [isChatOpen, setChatOpen] = useState(false);
    const [isSidebarCollapsed, setSidebarCollapsed] = useState(false);
    const [isMobileNavOpen, setMobileNavOpen] = useState(false);
    const [editingItem, setEditingItem] = useState(null);
    
    // --- Search State ---
    const [searchTerm, setSearchTerm] = useState('');
    const [submittedSearchTerm, setSubmittedSearchTerm] = useState(null); 
    const [activeFilters, setActiveFilters] = useState([]);
    const [showSearchPopover, setShowSearchPopover] = useState(false);
    const searchRef = useRef(null);

    // --- Effects for managing search UI ---
    useEffect(() => {
        const handleClickOutside = (event) => {
            if (searchRef.current && !searchRef.current.contains(event.target)) {
                setShowSearchPopover(false);
            }
        };
        document.addEventListener("mousedown", handleClickOutside);
        return () => document.removeEventListener("mousedown", handleClickOutside);
    }, []);
    
    // --- Event Handlers ---
    const handleFilterChange = (filterType) => {
        setActiveFilters(prev => 
            prev.includes(filterType) 
            ? prev.filter(f => f !== filterType)
            : [...prev, filterType]
        );
        if(!showSearchPopover) setShowSearchPopover(true);
    };

    const handleSearchKeyDown = (event) => {
        if (event.key === 'Enter') {
            setSubmittedSearchTerm(searchTerm);
            setShowSearchPopover(true);
        } else if (event.key === 'Escape') {
            setShowSearchPopover(false);
        }
    };
    
    const handleSearchFocus = () => setShowSearchPopover(true);
    
    const openModal = (items, title) => {
        setModalContent({ items, title });
        setActiveItem(title);
    };
    
    const closeModal = () => {
        setModalContent(null);
        if (!editingItem) {
            setActiveItem('Dashboard');
        }
    };

    const handleSelectItem = (item) => {
        setEditingItem(item);
        setActiveItem(item.name);
        closeModal();
    };

    const toggleNotifications = () => setNotificationsOpen(prev => !prev);

    const renderContent = () => {
        if (editingItem) {
            if (editingItem.type === 'Compute') {
                return <ComputePage item={editingItem} setEditingItem={setEditingItem} />;
            }
        }
        if (activeItem === 'Dashboard') return <AiDashboard />;
        return <GenericPagePlaceholder pageTitle={activeItem} />;
    };
    
    const pageTitle = editingItem ? editingItem.name : activeItem;

    return (
        <div className="bg-gray-100 min-h-screen">
            <style>{`
                @keyframes float { 0% { transform: translateY(0px); } 50% { transform: translateY(-10px); } 100% { transform: translateY(0px); } }
                .animate-float { animation: float 6s ease-in-out infinite; }
                @keyframes pulse-slow { 0% { opacity: 0.1; transform: scale(0.95); } 50% { opacity: 0.2; transform: scale(1.05); } 100% { opacity: 0.1; transform: scale(0.95); } }
                .animate-pulse-slow { animation: pulse-slow 8s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
                @keyframes fade-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
                .animate-fade-in { animation: fade-in 0.7s ease-out forwards; }
                .prose { max-width: 65ch; color: #374151; }
                .prose ul { padding-left: 1.25rem; }
                .prose ul > li { margin-top: 0.5em; margin-bottom: 0.5em; }
            `}</style>
        
            {isMobileNavOpen && <div className="fixed inset-0 bg-black/30 z-30 lg:hidden" onClick={() => setMobileNavOpen(false)}></div>}

            <Sidebar
                activeItem={activeItem}
                setActiveItem={setActiveItem}
                openModal={openModal}
                isCollapsed={isSidebarCollapsed}
                setEditingItem={setEditingItem}
                isMobileNavOpen={isMobileNavOpen}
            />
            
            <div className={`transition-all duration-300 ${isSidebarCollapsed ? 'lg:pl-20' : 'lg:pl-64'}`}>
                <div className="flex flex-col min-h-screen">
                    <TopBar 
                        openNotifications={toggleNotifications}
                        setSidebarCollapsed={setSidebarCollapsed}
                        isSidebarCollapsed={isSidebarCollapsed}
                        setMobileNavOpen={setMobileNavOpen} 
                        title={pageTitle}
                        searchRef={searchRef}
                        onSearchKeyDown={handleSearchKeyDown}
                        onSearchFocus={handleSearchFocus}
                        searchTerm={searchTerm}
                        setSearchTerm={setSearchTerm}
                        onFilterToggle={() => setShowSearchPopover(prev => !prev)}
                        editingItem={editingItem}
                        showSearchPopover={showSearchPopover}
                    />
                    <main className="flex-1">
                        {renderContent()}
                    </main>
                </div>
            </div>

            <ListModal isOpen={!!modalContent} content={modalContent} onClose={closeModal} onSelectItem={handleSelectItem} />
            <NotificationsPanel isOpen={isNotificationsOpen} closePanel={() => setNotificationsOpen(false)} />
            
            {activeItem !== 'Dashboard' && (
                <button 
                    onClick={() => setChatOpen(true)}
                    className="fixed bottom-6 right-6 w-14 h-14 bg-gradient-to-br from-purple-500 to-indigo-600 text-white rounded-full flex items-center justify-center shadow-lg hover:scale-105 transition-transform"
                    style={{ boxShadow: '0 4px 12px rgba(139, 92, 246, 0.3)' }}
                    aria-label="Open AI Chat"
                >
                    <ChatBubbleIcon className="w-7 h-7" />
                </button>
            )}
            <ChatModal isOpen={isChatOpen} closeChatbot={() => setChatOpen(false)} context={activeItem} />
        </div>
    );
};

export default function App() {
    return <DashboardLayout />;
}
