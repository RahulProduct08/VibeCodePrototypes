const UnifiedSearchPopover = ({ submittedSearchTerm, activeFilters, onFilterChange }) => {
    
    const filteredItems = allSearchableItems.filter(item => {
        const searchTermMatch = submittedSearchTerm ? (item.name.toLowerCase().includes(submittedSearchTerm.toLowerCase()) || item.summary.toLowerCase().includes(submittedSearchTerm.toLowerCase())) : true;
        if (!searchTermMatch && submittedSearchTerm) return false;

        const filterMatch = activeFilters.length > 0 ? activeFilters.includes(item.type) : true;
        return filterMatch;
    });

    const groupedItems = filteredItems.reduce((acc, item) => {
        const { type } = item;
        if (!acc[type]) acc[type] = [];
        acc[type].push(item);
        return acc;
    }, {});
    
    const getIconForType = (type) => {
        const icons = {
            'Compute': <ComputeIcon className="w-4 h-4 text-gray-500" />,
            'Conditions': <ConditionsIcon className="w-4 h-4 text-gray-500" />,
            'Events': <EventsIcon className="w-4 h-4 text-gray-500" />,
            'Orchestrations': <OrchestrationIcon className="w-4 h-4 text-gray-500" />,
            'Party': <AccessIcon className="w-4 h-4 text-gray-500" />,
            'Policy': <PolicyIcon className="w-4 h-4 text-gray-500" />,
            'Client': <UserCircleIcon className="w-4 h-4 text-gray-500" />,
            'Notes': <NoteIcon className="w-4 h-4 text-gray-500" />,
        };
        return icons[type] || null;
    };

    const filterOptions = ['Compute', 'Conditions', 'Events', 'Orchestrations', 'Party', 'Policy', 'Client', 'Notes'];
    
    return (
        <div className="absolute top-full mt-2 w-full bg-white rounded-xl shadow-2xl border border-gray-200/80 overflow-hidden" style={{maxHeight: '70vh'}}>
            <div className="p-4 border-b border-gray-200">
                <h3 className="text-sm font-semibold text-gray-800">Search Filters</h3>
                <div className="flex flex-wrap gap-2 mt-2">
                     {filterOptions.map(type => (
