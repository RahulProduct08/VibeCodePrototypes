# Copy to .env and fill in your values (never commit .env)

# Required: Anthropic API key for AI agents
ANTHROPIC_API_KEY=sk-ant-...

# Optional: leave blank to use local SQLite (rules.db)
# Railway auto-injects this when you add a Postgres plugin
# Render auto-injects this when you add a Postgres database
DATABASE_URL=

# Port (Railway and Render inject this automatically)
PORT=8000
